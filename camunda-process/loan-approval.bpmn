<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_07ei2ym" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="loan-approval" name="Loan Approval" isExecutable="true">
    <bpmn:startEvent id="loan-request-received" name="Loan Request Received">
      <bpmn:extensionElements />
      <bpmn:outgoing>Flow_1cqtw8d</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1cqtw8d" sourceRef="loan-request-received" targetRef="enter-loan-details-form" />
    <bpmn:userTask id="enter-loan-details-form" name="Enter Loan Details">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="loan-detail-form" />
        <zeebe:ioMapping>
          <zeebe:input source="=customerId" target="customerId" />
          <zeebe:output source="=customerId" target="customerId" />
          <zeebe:output source="=amount" target="amount" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1cqtw8d</bpmn:incoming>
      <bpmn:outgoing>Flow_1jocup2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1jocup2" sourceRef="enter-loan-details-form" targetRef="credit-check" />
    <bpmn:serviceTask id="credit-check" name="Credit Check">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=customerId" target="customerId" />
          <zeebe:input source="=amount" target="amount" />
          <zeebe:output source="=output.creditScore" target="creditScore" />
        </zeebe:ioMapping>
        <zeebe:taskDefinition type="check-credit" retries="3" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jocup2</bpmn:incoming>
      <bpmn:outgoing>Flow_1qdqyuh</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1qdqyuh" sourceRef="credit-check" targetRef="send-email" />
    <bpmn:endEvent id="Event_005nmvb" name="Approved">
      <bpmn:incoming>Flow_0vbfsuy</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0vbfsuy" sourceRef="send-email" targetRef="Event_005nmvb" />
    <bpmn:serviceTask id="send-email" name="Send Email">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="send-email" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1qdqyuh</bpmn:incoming>
      <bpmn:outgoing>Flow_0vbfsuy</bpmn:outgoing>
    </bpmn:serviceTask>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="loan-approval">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="loan-request-received">
        <dc:Bounds x="182" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="166" y="185" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_1mb2xma_di" bpmnElement="enter-loan-details-form">
        <dc:Bounds x="300" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_05tm4g5_di" bpmnElement="credit-check">
        <dc:Bounds x="480" y="120" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_005nmvb_di" bpmnElement="Event_005nmvb">
        <dc:Bounds x="862" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="857" y="185" width="47" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_0hk0g5j_di" bpmnElement="send-email">
        <dc:Bounds x="660" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1cqtw8d_di" bpmnElement="Flow_1cqtw8d">
        <di:waypoint x="218" y="160" />
        <di:waypoint x="300" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1jocup2_di" bpmnElement="Flow_1jocup2">
        <di:waypoint x="400" y="160" />
        <di:waypoint x="480" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_1qdqyuh_di" bpmnElement="Flow_1qdqyuh">
        <di:waypoint x="580" y="160" />
        <di:waypoint x="660" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_0vbfsuy_di" bpmnElement="Flow_0vbfsuy">
        <di:waypoint x="760" y="160" />
        <di:waypoint x="862" y="160" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
